{
  "name": "ai-delta-reader-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:annotation-debug": "tsc -p tsconfig.debug.json",
    "debug:annotations": "npm run build:annotation-debug --silent && node .annotation-debug-build/src/debug/annotationCli.js",
    "test:annotations": "npm run build:annotation-debug --silent && node .annotation-debug-build/src/debug/annotationDiagnostics.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "pdfjs-dist": "4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4"
  }
}
